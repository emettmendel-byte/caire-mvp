                "no": "out_routine"
            },
            "label": "Does the patient have fever (>38°C)?",
            "description": "Oral or tympanic temperature",
            "condition": {
                "variable": "entry_point",
                "operator": "==",
                "threshold": "start_assessment"
            },
            "metadata": {
                "question": {
                    "value_type": "number",
                    "unit": "C",
                    "threshold": 38,
                    "options": [
                        "yes",
                        "no"
                    ]
                }
            }
        },
        {
            "id": "q_breathing",
            "type": "question",
            "origin": "q_fever",
            "output_type": "string",
            "output_map": {
                "yes": "out_urgent",
                "no": "out_routine"
            },
            "label": "Difficulty breathing or chest pain?",
            "description": "Acute dyspnea or chest discomfort",
            "condition": {
                "variable": "q_fever",
                "operator": "==",
                "threshold": "yes"
            },
            "metadata": {
                "question": {
                    "value_type": "string",
                    "options": [
                        "yes",
                        "no",
                        "unknown"
                    ]
                }
            }
        },
        {
            "id": "out_urgent",
            "type": "outcome",
            "origin": "q_breathing",
            "label": "Urgent – seek emergency care",
            "description": "Recommend ED or urgent evaluation",
            "condition": {
                "variable": "q_breathing",
                "operator": "==",
                "threshold": "yes"
